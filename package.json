{
    "name":  "dyscalculia-support-skill",
    "version":  "1.2.0",
    "description":  "Multi-format dyscalculia support system for CRA methodology, standards compliance, and IEP generation",
    "author":  "Justice",
    "license":  "MIT",
    "type":  "module",
    "scripts":  {
                    "build":  "tsx build.ts",
                    "build:watch":  "tsx build.ts --watch",
                    "type-check":  "tsc --noEmit",
                    "audit":  "npm audit --audit-level=high",
                    "sbom":  "npx @cyclonedx/cyclonedx-npm --output-file sbom.cdx.json --output-reproducible",
                    "clean":  "rm -rf dist",
                    "build:claude-plugin":  "tsx build.ts --format claude-plugin",
                    "build:mcp":  "tsx build.ts --format mcp-server",
                    "build:openai":  "tsx build.ts --format openai",
                    "build:n8n":  "tsx build.ts --format n8n",
                    "build:prompts":  "tsx build.ts --format prompts",
                    "build:cli":  "tsx build.ts --format cli"
                },
    "devDependencies":  {
                            "@types/node":  "^20.10.0",
                            "typescript":  "^5.3.3",
                            "tsx":  "^4.7.0",
                            "zod":  "^3.22.4"
                        },
    "keywords":  [
                     "dyscalculia",
                     "math-disability",
                     "CRA",
                     "concrete-representational-abstract",
                     "number-sense",
                     "math-anxiety",
                     "NCTM",
                     "IDEA",
                     "section-504",
                     "IEP",
                     "remediation",
                     "special-education",
                     "accessibility",
                     "EdTech"
                 ],
    "repository":  {
                       "type":  "git",
                       "url":  "https://github.com/justice8096/dyscalculia-support-skill.git"
                   }
}
